{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coord/gates/affected-targets.schema.json",
  "title": "Coord Affected Target Map",
  "type": "object",
  "required": ["schema_version", "full_gate", "targets"],
  "properties": {
    "schema_version": { "const": 1 },
    "updated_at": { "type": "string" },
    "full_gate": {
      "type": "object",
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "command", "files"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
